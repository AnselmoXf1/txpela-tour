# Configurações do Django
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,75.119.133.19,your-domain.com

# Banco de dados (SQLite para desenvolvimento, PostgreSQL para produção)
# SQLite (desenvolvimento)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (produção - descomente e configure)
# DATABASE_URL=postgresql://user:password@localhost:5432/txopela_db

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=txopela_db

# Google Gemini AI
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Cloudinary (para upload de imagens)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://75.119.133.19
CORS_ALLOW_ALL_ORIGINS=False

# Email (opcional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO

# Security (produção)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# Timezone
TIME_ZONE=Africa/Maputo
USE_TZ=True

# Static files
STATIC_URL=/static/
STATIC_ROOT=/var/www/txopela/staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/txopela/media/